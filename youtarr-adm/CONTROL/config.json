{
  "general": {
    "package": "youtarr-docker",
    "name": "Youtarr",
    "version": "1.76.1",
    "depends": [
      "docker-ce(>=20.10.17.r1)"
    ],
    "developer": "DialmasterOrg",
    "maintainer": "Orbernator",
    "email": "contactus@teamorbi.net",
    "website": "https://youtarr.com",
    "architecture": "x86-64",
    "firmware": "5.0.0"
  },
  "adm-desktop": {
    "app": {
      "port": 3087,
      "protocol": "http",
      "type": "custom",
      "url": "/"
    },
    "privilege": {
      "accessible": "users",
      "customizable": true
    }
  },
  "register": {
    "share-folder": [
      {
        "name": "Docker",
        "description": "Data and files directory for Docker Apps"
      },
      {
        "name": "Download",
        "description": "Folder for Downloads to go into"
      },
      {
        "name": "Media",
        "description": "Media for Asustor users"
      }
    ],
    "boot-priority": {
      "start-order": 70,
      "stop-order": 30
    },
    "port": [
      "T3087"
    ]
  }
}
