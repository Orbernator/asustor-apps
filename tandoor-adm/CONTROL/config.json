{
  "general":{
    "package":"tandoor-docker",
    "name":"Tandoor",
    "version":"2.6.13",
    "depends":[
      "docker-ce(>=20.10.17.r1)"
    ],
    "developer":"vabene1111",
    "maintainer":"Orbernator",
    "email":"contactus@teamorbi.net",
    "website":"https://docs.tandoor.dev",
    "architecture":"x86-64",
    "firmware":"3.5.0"
  },
  "adm-desktop":{
    "app":{
      "port":9928,
      "protocol":"http",
      "type":"custom",
      "url":"/" 
    },
    "privilege":{
      "accessible":"users", 
      "customizable":true 
    }
  },
  "register":{
    "share-folder":[
      {
        "name":"Docker",
        "description":"Data and files directory for Docker Apps"
      },
      {
      	"name":"Media",
      	"description":"Media for apps and users"
      }	
    ],
    "boot-priority":{
      "start-order":70,
      "stop-order":30
    },
    "port":[
      "T9928"
    ]
  }
}
