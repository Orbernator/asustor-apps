{
  "general":{
    "package":"tunarr-docker",
    "name":"Tunarr",
    "version":"1.3.8.r01",
    "depends":[
      "docker-ce(>=20.10.17.r1)"
    ],
    "developer":"Tunarr",
    "maintainer":"Orbernator",
    "email":"contactus@teamorbi.net",
    "website":"https://tunarr.com/",
    "architecture":"x86-64",
    "firmware":"3.5.0"
  },
  "adm-desktop":{
    "app":{
      "port":8000,
      "protocol":"http",
      "type":"custom",
      "url":"/" 
    },
    "privilege":{
      "accessible":"users", 
      "customizable":true 
    }
  },
  "register":{
    "share-folder":[
      {
        "name":"Docker",
        "description":"Data and files directory for Docker Apps"
      }           
    ],
    "boot-priority":{
      "start-order":70,
      "stop-order":30
    },
    "port":[
      "T8000"
    ]
  }
}
