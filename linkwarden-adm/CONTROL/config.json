{
  "general": {
    "package": "linkwarden-docker",
    "name": "Linkwarden",
    "version": "2.15.1-o1",
    "depends": [
      "docker-ce(>=20.10.17.r1)"
    ],
    "developer": "Linkwarden",
    "maintainer": "Orbernator",
    "email": "contactus@teamorbi.net",
    "website": "https://docs.linkwarden.org",
    "architecture": "x86-64",
    "firmware": "5.0.0"
  },
  "adm-desktop": {
    "app": {
      "port": 5465,
      "protocol": "http",
      "type": "custom",
      "url": "/"
    },
    "privilege": {
      "accessible": "users",
      "customizable": true
    }
  },
  "register": {
    "share-folder": [
      {
        "name": "Docker",
        "description": "Data and files directory for Docker Apps"
      }
    ],
    "boot-priority": {
      "start-order": 70,
      "stop-order": 30
    },
    "port": [
      "T5465"
    ]
  }
}
